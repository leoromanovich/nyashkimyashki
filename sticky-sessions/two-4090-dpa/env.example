# Required: set these to the actual model configured on the 2x4090 host.
HOST_MODEL_PATH=
SERVED_MODEL_NAME=
LITELLM_UPSTREAM_MODEL=
OPENWEBUI_DEFAULT_MODEL=

WEBUI_SECRET_KEY=change-me-random-hex
WEBUI_ADMIN_EMAIL=admin@example.com
WEBUI_ADMIN_PASSWORD=change-me

SGLANG_PORT=30000
SMG_PORT=30100
SMG_METRICS_PORT=29100
LITELLM_PORT=4010
OPENWEBUI_PORT=8090
OWUI_WRAPPER_PORT=8091

CUDA_VISIBLE_DEVICES=0,1
SGLANG_TP=2
SGLANG_DP=2
CONTEXT_LENGTH=32768
SGLANG_REASONING_PARSER=qwen3
SGLANG_KV_CACHE_DTYPE=fp8_e4m3
SGLANG_PAGE_SIZE=64
CHUNKED_PREFILL_SIZE=8192
MAX_PREFILL_TOKENS=8192
MAX_RUNNING_REQUESTS=32
CUDA_GRAPH_MAX_BS=8
